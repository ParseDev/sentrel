# Alchemy engine — example environment file.
# Copy to `.env` and fill in the values relevant for your environment.
# One engine instance runs per agent.

# ─── Core ────────────────────────────────────────────────────────────────────
# Numeric agents.id this engine instance serves. Used for queue key
# `employee-<id>`, Redis `health:<id>`, and Postgres lookups. Never a
# prefix_id here — engine stays numeric end-to-end.
EMPLOYEE_ID=1

DATABASE_URL=postgres://localhost:5432/alchemy_development
REDIS_URL=redis://localhost:6379/0
DATA_DIR=./workspace
GATEWAY_PORT=3300
LOG_LEVEL=info

# Must match ENGINE_API_SECRET in Rails `.env`.
ENGINE_API_SECRET=

# Rails base URL. Used for /api/blobs, /api/task_events callbacks, and
# media asset URLs returned to channels.
RAILS_INTERNAL_URL=http://localhost:3200
RAILS_API_URL=http://localhost:3200
RAILS_PUBLIC_URL=http://localhost:3200

# ─── LLM provider ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
# Optional override for routing through a gateway (proxy, etc.).
ANTHROPIC_BASE_URL=

# Fine-grained model overrides (defaults set in code).
# SUMMARIZE_MODEL=claude-3-5-haiku-20241022
# CONTEXTUAL_RETRIEVAL_MODEL=claude-3-5-haiku-20241022

# ─── Integrations: Composio ──────────────────────────────────────────────────
# Same value as Rails `.env`. Engine uses it to fetch tool schemas and
# execute tool calls against the user's connected accounts.
COMPOSIO_API_KEY=
# Circuit-breaker timeout; requests longer than this trip the breaker and
# the agent falls back to baseline tools.
COMPOSIO_TIMEOUT_MS=5000

# ─── Media (optional) ────────────────────────────────────────────────────────
# OpenAI — used for audio transcription (Whisper) and TTS fallback.
OPENAI_API_KEY=
# TRANSCRIPTION_MODEL=whisper-1
# TTS_PROVIDER=openai     # openai | elevenlabs | cartesia
# TTS_MODEL=tts-1-hd
# TTS_VOICE=alloy

# ElevenLabs (alternate TTS).
ELEVENLABS_API_KEY=
# ELEVENLABS_MODEL=eleven_turbo_v2_5
# ELEVENLABS_VOICE_ID=

# Cartesia (alternate TTS).
CARTESIA_API_KEY=
# CARTESIA_VOICE_ID=

# ─── Channels (optional) ─────────────────────────────────────────────────────
# Twilio — used for outbound WhatsApp/SMS. Inbound comes via Rails webhook.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Default WhatsApp sender, overridden per-channel-config at runtime.
WHATSAPP_BOT_NUMBER=

# ─── Feature flags ───────────────────────────────────────────────────────────
# Tool routing: "smart" = L1 (audit history) + L2 (embedding match on user
# message) + on-demand search; "all" = preload every connected toolkit
# (debugging only — burns tokens).
TOOL_ROUTING=smart

# Resume Claude sessions across jobs when possible (cuts input tokens).
RESUME_ENABLED=true

# Threshold for Haiku-summarizing long search hits.
SEARCH_SUMMARIZE_THRESHOLD=5

# ─── Observability (optional) ────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_TRACES_RATE=0.1
BETTERSTACK_SOURCE_TOKEN=
GIT_SHA=
