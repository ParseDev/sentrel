#!/usr/bin/env sh
# Root orchestrator — installs both halves of the monorepo.
set -e
HERE="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(cd "$HERE/.." && pwd)"

echo "== backend (Rails) =="
cd "$ROOT/backend" && ./bin/setup --skip-server

echo ""
echo "== engine (TypeScript sidecar) =="
if command -v bun > /dev/null 2>&1; then
  cd "$ROOT/engine" && bun install --frozen-lockfile
else
  echo "  ⚠  bun not installed — skipping engine deps. Install at https://bun.sh"
fi

echo ""
echo "Setup complete."
echo "Run 'bin/dev' from repo root to start Rails + Vite + Sidekiq + Engine."
